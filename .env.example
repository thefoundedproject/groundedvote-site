# Database (Railway PostgreSQL — copy from Railway dashboard)
# For high-traffic: append ?connection_limit=10&pool_timeout=20
# If using Railway's Pgbouncer proxy: also add &pgbouncer=true
DATABASE_URL="postgresql://user:password@host:port/dbname?connection_limit=10&pool_timeout=20"

# Email (Resend — https://resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# AI — Bias audit pipeline
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxx"
OPENAI_API_KEY="sk-xxxxxxxxxxxx"

# Candidate data (Congress.gov — free key at https://api.congress.gov)
CONGRESS_API_KEY="xxxxxxxxxxxx"

# Admin protection for /api/admin/generate
ADMIN_SECRET="choose-a-strong-random-string"

# Stripe keys (already added to Railway)
STRIPE_SECRET_KEY="sk_live_xxxxxxxxxxxx"
STRIPE_PUBLISHABLE_KEY="pk_live_xxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

# Base URL (for Stripe redirect URLs)
NEXT_PUBLIC_BASE_URL="https://groundedvote.com"

# Stripe Price IDs — create products in dashboard, paste IDs here
# Dashboard → Product catalog → Add product → Add price → copy price ID (price_xxxx)
STRIPE_GV_DONATION_PRICE_ID=""       # GroundedVote one-time donation (if using fixed price)
STRIPE_GV_MONTHLY_PRICE_ID=""        # GroundedVote monthly supporter

STRIPE_RP_STARTER_PRICE_ID=""        # RhetoricalPoints 500 credits
STRIPE_RP_PRO_PRICE_ID=""            # RhetoricalPoints 2,500 credits
STRIPE_RP_SCALE_PRICE_ID=""          # RhetoricalPoints 10,000 credits
STRIPE_RP_MONTHLY_PRICE_ID=""        # RhetoricalPoints monthly subscription

STRIPE_RR_MONTHLY_PRICE_ID=""        # RootedReclaimers monthly membership
STRIPE_RR_ANNUAL_PRICE_ID=""         # RootedReclaimers annual membership

STRIPE_LLV_MONTHLY_PRICE_ID=""       # LowLight Vibes monthly access
